# Regenerable F8 ROM disassembly listings.
#
# Tool: MAME unidasm (mame-tools apt package) for disassembly.
#       Macro Assembler AS (asl) for round-trip verification.
#
# Usage:
#   make              # regenerate all .asm listings
#   make U1.asm       # regenerate one ROM
#   make strings      # extract printable strings from each ROM
#   make verify       # round-trip: re-assemble each .asm and hash-compare to ROM
#   make clean        # remove generated files
#
# Phase-1 discipline: keep ORIGIN values as WORKING HYPOTHESES until
# load_address_verification.md says CONFIRMED. Wrong origins produce
# nonsense disassembly (mid-instruction branches everywhere).

ROM_DIR := ../roms

# Detect WSL/MSYS shim. On native Linux, use binaries directly.
UNAME := $(shell uname -s)
ifneq (,$(findstring MINGW,$(UNAME)))
ASL     := wsl -e asl
UNIDASM := wsl -e unidasm
P2BIN   := wsl -e p2bin
else ifneq (,$(findstring MSYS,$(UNAME)))
ASL     := wsl -e asl
UNIDASM := wsl -e unidasm
P2BIN   := wsl -e p2bin
else
ASL     := asl
UNIDASM := unidasm
P2BIN   := p2bin
endif

# === Per-project ROM definitions (generated by new-disasm-project.sh) ===
ROMS := U1 U12 U22 U55

U1.asm    strings_U1.txt    U1.verify:  ORIGIN := 0x0000
U1.asm    strings_U1.txt    U1.verify:  ROM    := ../roms/f2708_eprom_u1_6eaf59ae.bin
U12.asm   strings_U12.txt   U12.verify: ORIGIN := 0x0400
U12.asm   strings_U12.txt   U12.verify: ROM    := ../roms/mm2708q_eprom_u12_7162a6cc.bin
U22.asm   strings_U22.txt   U22.verify: ORIGIN := 0x0800
U22.asm   strings_U22.txt   U22.verify: ROM    := ../roms/mm2708q_eprom_u22_7c7cc3dd.bin
U55.asm   strings_U55.txt   U55.verify: ORIGIN := 0x0C00
U55.asm   strings_U55.txt   U55.verify: ROM    := ../roms/mm2716q_eprom_u55_08658dd6.bin
# ============================================================================
DASM_RAW := $(addsuffix .raw,$(ROMS))

.PHONY: all strings verify clean

all: $(addsuffix .asm,$(ROMS))

# Disassemble: unidasm produces raw mnemonics, relabel.py substitutes .sym labels.
%.asm: %.sym
	@if [ ! -f $*.sym ]; then echo "; (no .sym yet) — seed in $*.sym" > $*.sym; fi
	$(UNIDASM) -arch f8 -basepc $(ORIGIN) $(ROM) > $*.raw
	python3 tools/relabel.py --sym $*.sym --base $(ORIGIN) --rom $(ROM) < $*.raw > $@
	rm -f $*.raw

# String extraction (printable ASCII runs >= 4 bytes).
strings: $(addprefix strings_,$(addsuffix .txt,$(ROMS)))
strings_%.txt:
	python3 tools/extract_strings.py --base $(ORIGIN) $(ROM) > $@

# Round-trip verification: re-assemble .asm and compare to source ROM.
verify: $(addsuffix .verify,$(ROMS))
%.verify: %.asm
	@$(ASL) -cpu MK3850 -relaxed -L $< -o $*.p > $*.aslog 2>&1 || \
	    (echo "  ✗ $*: AS error — see $*.aslog" && false)
	@$(P2BIN) -r '$$-$$' $*.p $*-rebuilt.bin >/dev/null 2>&1
	@if cmp -s $*-rebuilt.bin $(ROM); then \
	    sha=$$(sha256sum $*-rebuilt.bin | cut -d' ' -f1); \
	    echo "  ✓ $*: round-trip exact ($$sha)"; \
	else \
	    bytes=$$(cmp -l $*-rebuilt.bin $(ROM) 2>/dev/null | wc -l); \
	    echo "  ✗ $*: $$bytes bytes differ —"; \
	    cmp -l $*-rebuilt.bin $(ROM) 2>/dev/null | head -10; \
	fi

clean:
	rm -f $(addsuffix .asm,$(ROMS)) $(addsuffix .raw,$(ROMS)) \
	      $(addsuffix .p,$(ROMS)) $(addsuffix .aslog,$(ROMS)) \
	      $(addsuffix .lst,$(ROMS)) \
	      $(addsuffix -rebuilt.bin,$(ROMS)) strings_*.txt
